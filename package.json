{
  "name": "hadaf",
  "version": "0.0.0-bootstrap",
  "description": "HAUTM Agentic Delivery & Assurance Framework",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22.0.0 <25",
    "pnpm": ">=10.0.0 <11"
  },
  "scripts": {
    "build": "tsc -b packages/kernel",
    "test": "pnpm build && node --test \"packages/kernel/dist/**/*.test.js\"",
    "quality": "node scripts/run-quality-gates.mjs",
    "quality:report": "node scripts/run-quality-gates.mjs --json",
    "hmc:serve": "node scripts/serve-hmc.mjs",
    "hmc:smoke": "node scripts/serve-hmc.mjs --smoke",
    "verify:hmc-state": "node scripts/verify-hmc-state.mjs",
    "preview:serve": "node scripts/serve-product-preview.mjs",
    "preview:smoke": "node scripts/serve-product-preview.mjs --smoke",
    "verify:product-preview": "node scripts/verify-product-preview.mjs",
    "verify:static-ui": "node scripts/verify-static-ui.mjs",
    "check:package": "node scripts/check-package-metadata.mjs",
    "check:license": "node scripts/check-no-license-file.mjs",
    "check:cli-args": "pnpm build && node scripts/check-cli-arg-normalization.mjs",
    "check:public": "node scripts/check-public-safety.mjs",
    "check:public:self-test": "node scripts/check-public-safety.mjs --self-test",
    "check:target-guard": "pnpm build && node scripts/check-target-guard.mjs",
    "check:target-guard:self-test": "pnpm build && node scripts/check-target-guard.mjs --self-test",
    "check:pr-metadata": "node scripts/check-pr-metadata-public-safety.mjs --self-test",
    "check:ci": "node scripts/check-ci-workflow.mjs",
    "check:deps": "node scripts/check-dependency-licenses.mjs",
    "check:deps:self-test": "node scripts/check-dependency-licenses.mjs --self-test",
    "classify:source-authority": "node scripts/classify-source-authority.mjs",
    "check:supply-chain": "node scripts/generate-supply-chain-artifacts.mjs --check",
    "verify:evidence": "node scripts/verify-evidence-manifest.mjs",
    "verify:source-manifest": "node scripts/verify-source-manifest.mjs",
    "verify:quality-classification": "node scripts/verify-quality-classification.mjs",
    "verify:status": "node scripts/reconcile-status.mjs",
    "verify:h03-schema-registry": "node scripts/verify-h03-schema-registry.mjs",
    "verify:h03-input-authority": "node scripts/verify-h03-input-authority.mjs",
    "verify:h03-plan-normalization": "node scripts/verify-h03-plan-normalization.mjs",
    "verify:h03-question-register": "node scripts/verify-h03-question-register.mjs",
    "verify:h03-delivery-constitution": "node scripts/verify-h03-delivery-constitution.mjs",
    "verify:h03-constitution-readiness": "node scripts/verify-h03-constitution-readiness.mjs",
    "verify:h03-ratification-readiness": "node scripts/verify-h03-ratification-readiness.mjs",
    "verify:h05-agent-registry": "node scripts/verify-h05-agent-registry.mjs",
    "verify:h05-capability-contracts": "node scripts/verify-h05-capability-contracts.mjs",
    "verify:h05-circuit-breakers": "node scripts/verify-h05-circuit-breakers.mjs",
    "verify:h05-upskill-records": "node scripts/verify-h05-upskill-records.mjs",
    "verify:h05-agent-projection": "node scripts/verify-h05-agent-projection.mjs",
    "verify:h06-resource-quotas": "node scripts/verify-h06-resource-quotas.mjs",
    "verify:h06-worktree-lifecycle": "node scripts/verify-h06-worktree-lifecycle.mjs",
    "verify:h06-locks-checkpoints-quarantine": "node scripts/verify-h06-locks-checkpoints-quarantine.mjs",
    "verify:h06-pod-scheduler": "node scripts/verify-h06-pod-scheduler.mjs",
    "verify:h06-local-lifecycle-runner": "node scripts/verify-h06-local-lifecycle-runner.mjs",
    "verify:h07-evidence-eligibility": "node scripts/verify-h07-evidence-eligibility.mjs",
    "verify:h07-proof-package": "node scripts/verify-h07-proof-package.mjs",
    "verify:h07-proof-verifier": "node scripts/verify-h07-proof-verifier.mjs",
    "verify:h07-proof-projection": "node scripts/verify-h07-proof-projection.mjs",
    "verify:h08-git-truth": "node scripts/verify-h08-git-truth.mjs",
    "verify:h08-pr-lifecycle": "node scripts/verify-h08-pr-lifecycle.mjs",
    "verify:h08-ci-watcher": "node scripts/verify-h08-ci-watcher.mjs",
    "verify:h08-merge-readiness": "node scripts/verify-h08-merge-readiness.mjs",
    "verify:h08-conductor": "node scripts/verify-h08-conductor.mjs",
    "verify:h08-git-projection": "node scripts/verify-h08-git-projection.mjs",
    "supply-chain": "node scripts/generate-supply-chain-artifacts.mjs"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  }
}
