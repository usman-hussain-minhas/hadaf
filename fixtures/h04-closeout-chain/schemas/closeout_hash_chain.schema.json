{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixture://schemas/closeout_hash_chain.schema.json",
  "title": "H04 Closeout Hash Chain Fixture Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "chain_id",
    "scope_type",
    "scope_id",
    "ordered_links",
    "chain_status",
    "stale_links",
    "cannot_claim"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "chain_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_type": {
      "enum": [
        "box",
        "ffet",
        "part",
        "schema_amendment",
        "runtime",
        "system"
      ]
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "ordered_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "link_id",
          "ref",
          "sha256",
          "role"
        ],
        "properties": {
          "link_id": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "pattern": "^(fixture://|schema://)[^\\s]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^(sha256:)?[a-f0-9]{64}$"
          },
          "role": {
            "enum": [
              "source",
              "artifact_bundle",
              "evidence_manifest",
              "assurance",
              "closeout",
              "current_state",
              "continuation",
              "learning",
              "validation",
              "runtime"
            ]
          }
        }
      }
    },
    "source_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "artifact_bundle_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "assurance_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "closeout_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "current_state_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "continuation_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "chain_status": {
      "enum": [
        "valid",
        "stale",
        "broken",
        "unable_to_verify"
      ]
    },
    "stale_links": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cannot_claim": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
