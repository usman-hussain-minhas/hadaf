{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixture://schemas/h04_h06_lifecycle_common.definitions.schema.json",
  "title": "HADAF H04-H06 Lifecycle Common Definitions",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "definitions_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_version",
    "definitions_version"
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "ref": {
      "type": "string",
      "pattern": "^(control|evidence|runtime|product|input|release)://[^\\s]+$|^[A-Za-z0-9_./:-]+$",
      "not": {
        "pattern": "^/"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^(?!.*(?:pending|placeholder|todo|TBD|FIXME))[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "cannotClaim": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifactPurpose": {
      "enum": [
        "authority",
        "control",
        "evidence",
        "runtime",
        "product_fixture",
        "generated_view",
        "validation",
        "closeout",
        "learning",
        "assurance",
        "current_state",
        "continuation",
        "draft"
      ]
    },
    "truthSourceClass": {
      "enum": [
        "human_ratification",
        "accepted_control",
        "canonical_bundle",
        "product_git",
        "github_truth",
        "evidence_attestation",
        "runtime_state",
        "generated_view",
        "fixture_state",
        "unavailable",
        "stale",
        "conflicting"
      ]
    },
    "freshnessStatus": {
      "enum": [
        "fresh",
        "stale",
        "superseded",
        "unknown",
        "not_applicable_with_reason"
      ]
    },
    "plane": {
      "enum": [
        "product",
        "control",
        "evidence",
        "runtime",
        "release",
        "input"
      ]
    },
    "refHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "sha256"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^(control|evidence|runtime|product|input|release)://[^\\s]+$|^[A-Za-z0-9_./:-]+$",
          "not": {
            "pattern": "^/"
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^(?!.*(?:pending|placeholder|todo|TBD|FIXME))[a-f0-9]{64}$"
        }
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "status"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "blocked",
            "not_applicable_with_reason",
            "unable_to_verify"
          ]
        },
        "detail": {
          "type": "string"
        },
        "evidence_ref": {
          "type": "string",
          "pattern": "^(control|evidence|runtime|product|input|release)://[^\\s]+$|^[A-Za-z0-9_./:-]+$"
        },
        "evidence_sha256": {
          "type": "string",
          "pattern": "^(?!.*(?:pending|placeholder|todo|TBD|FIXME))[a-f0-9]{64}$"
        }
      }
    },
    "gitObjectHash": {
      "type": "string",
      "pattern": "^(?!.*(?:pending|placeholder|todo|TBD|FIXME))[a-f0-9]{40}$",
      "description": "Git object identifier for commit/tree/blob references. Content hashes remain sha256."
    }
  }
}
