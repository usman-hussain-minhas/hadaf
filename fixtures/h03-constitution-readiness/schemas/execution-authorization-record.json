{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixture://h03-constitution-readiness/schemas/execution-authorization-record.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authorization_id",
    "constitution_id",
    "constitution_hash",
    "approval_record_ref",
    "approval_record_hash",
    "status",
    "authorized_scope",
    "forbidden_scope",
    "constraints",
    "human_gates",
    "ratifier",
    "authorized_at",
    "expires_at",
    "cannot_claim"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "authorization_id": {
      "type": "string",
      "minLength": 1
    },
    "constitution_id": {
      "type": "string",
      "minLength": 1
    },
    "constitution_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "approval_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "approval_record_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "status": {
      "enum": [
        "authorized",
        "suspended",
        "revoked",
        "completed"
      ]
    },
    "authorized_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "box_ids",
        "ffet_ids",
        "operations"
      ],
      "properties": {
        "box_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "ffet_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "forbidden_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "human_gates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "ratifier": {
      "type": "string",
      "minLength": 1
    },
    "authorized_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "cannot_claim": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
