      "human_decision_required": true,
      "hard_stop": true,
      "evidence_preserving_required": true,
      "cannot_claim": "schema_semantics_repair_without_human_decision"
    },
    {
      "class_id": "secret_or_private_data_exposure",
      "severity": "critical",
      "self_heal_allowed": false,
      "human_decision_required": true,
      "hard_stop": true,
      "evidence_preserving_required": true,
      "cannot_claim": "security_exposure_self_heal"
    },
    {
      "class_id": "licence_conflict",
      "severity": "critical",
      "self_heal_allowed": false,
      "human_decision_required": true,
