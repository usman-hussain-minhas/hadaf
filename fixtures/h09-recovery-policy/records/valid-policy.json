    },
    {
      "action_id": "append_only_supersession",
      "deterministic": true,
      "scoped": true,
      "evidence_preserving": true,
      "allowed": true
    },
    {
      "action_id": "quarantine",
      "deterministic": true,
      "scoped": true,
      "evidence_preserving": true,
      "allowed": true
    },
    {
      "action_id": "validation_rerun",
      "deterministic": true,
      "scoped": true,
      "evidence_preserving": true,
      "allowed": true
    },
    {
      "action_id": "rollback_routing",
      "deterministic": true,
      "scoped": true,
      "evidence_preserving": true,
      "allowed": true
    }
