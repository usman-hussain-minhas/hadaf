    {
      "class_id": "product_plane_contamination",
      "severity": "critical",
      "self_heal_allowed": false,
      "human_decision_required": true,
      "hard_stop": true,
      "evidence_preserving_required": true,
      "cannot_claim": "product_plane_contamination_self_heal"
