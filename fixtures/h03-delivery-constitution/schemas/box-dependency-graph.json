{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixture://schemas/box-dependency-graph.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_id",
    "version",
    "project_id",
    "constitution_id",
    "nodes",
    "edges",
    "topological_order",
    "cycle_status",
    "unresolved_dependencies",
    "cannot_claim"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "constitution_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "box_id",
          "name",
          "objective",
          "source_refs",
          "planning_status"
        ],
        "properties": {
          "box_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "planning_status": {
            "enum": [
              "candidate",
              "planned",
              "approved",
              "deferred",
              "blocked"
            ]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "topological_order": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "cycle_status": {
      "const": "acyclic"
    },
    "unresolved_dependencies": {
      "type": "array",
      "maxItems": 0
    },
    "cannot_claim": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
