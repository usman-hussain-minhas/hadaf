{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixture://schemas/delivery-constitution-v1-1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "constitution_id",
    "version",
    "project_id",
    "objective",
    "source_authority",
    "source_authority_set_hash",
    "source_mode",
    "target",
    "scope",
    "non_scope",
    "boxes",
    "structured_contracts",
    "question_resolution",
    "human_gates",
    "hash_contract",
    "completion_contract",
    "cannot_claim",
    "approval",
    "question_register_hash",
    "project_pack_ref",
    "quality_profile_ref",
    "quality_profile_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "constitution_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "business_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_authority": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "path_or_uri",
          "authority"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "path_or_uri": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_authority_set_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source_mode": {
      "const": "READ_ONLY_DIGEST"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "location",
        "mutation_allowed"
      ],
      "properties": {
        "type": {
          "enum": [
            "local_folder",
            "git_repository",
            "plan_only"
          ]
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "mutation_allowed": {
          "const": true
        }
      }
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boxes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "structured_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "box_dependency_graph",
        "agent_topology",
        "proof_matrix",
        "assurance_matrix",
        "resource_limits",
        "performance_environment_contract",
        "independent_review_policy"
      ],
      "properties": {
        "box_dependency_graph": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "agent_topology": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "proof_matrix": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "assurance_matrix": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "resource_limits": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "performance_environment_contract": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "independent_review_policy": {
          "$ref": "fixture://schemas/authority-ref.json"
        }
      }
    },
    "question_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_register",
        "ratified_answer_refs",
        "safe_default_policy_refs",
        "pending_local_question_limit",
        "correction_ffet_required_when_answer_differs",
        "zero_broad_ambiguity",
        "unresolved_broad_question_ids"
      ],
      "properties": {
        "question_register": {
          "$ref": "fixture://schemas/authority-ref.json"
        },
        "ratified_answer_refs": {
          "type": "array",
          "items": {
            "$ref": "fixture://schemas/authority-ref.json"
          }
        },
        "safe_default_policy_refs": {
          "type": "array",
          "items": {
            "$ref": "fixture://schemas/authority-ref.json"
          }
        },
        "pending_local_question_limit": {
          "type": "integer",
          "minimum": 0
        },
        "correction_ffet_required_when_answer_differs": {
          "const": true
        },
        "zero_broad_ambiguity": {
          "const": true
        },
        "unresolved_broad_question_ids": {
          "type": "array",
          "maxItems": 0
        }
      }
    },
    "public_commitments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_invariants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budgets": {
      "type": "object"
    },
    "hash_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "canonicalization",
        "content_hash_scope",
        "schema_sha256",
        "companion_hashes_included",
        "question_authority_included"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "canonicalization": {
          "const": "RFC8785"
        },
        "content_hash_scope": {
          "const": "document_excluding_approval"
        },
        "schema_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "companion_hashes_included": {
          "const": true
        },
        "question_authority_included": {
          "const": true
        }
      }
    },
    "completion_contract": {
      "type": "string",
      "minLength": 1
    },
    "cannot_claim": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "constitution_hash",
        "hash_algorithm",
        "canonicalization",
        "hash_scope",
        "approved_by",
        "approved_at",
        "approval_record_ref",
        "approval_record_hash"
      ],
      "properties": {
        "status": {
          "const": "for_human_review"
        },
        "constitution_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "hash_algorithm": {
          "const": "sha256"
        },
        "canonicalization": {
          "const": "RFC8785"
        },
        "hash_scope": {
          "const": "document_excluding_approval"
        },
        "approved_by": {
          "type": "null"
        },
        "approved_at": {
          "type": "null"
        },
        "approval_record_ref": {
          "type": "null"
        },
        "approval_record_hash": {
          "type": "null"
        }
      }
    },
    "question_register_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "project_pack_ref": {
      "type": "string"
    },
    "ratified_default_policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_policy": {
      "type": "string"
    },
    "retirement_contract_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "quality_profile_ref": {
      "type": "string"
    },
    "quality_profile_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "quality_override_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality_debt_policy_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "release_quality_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
