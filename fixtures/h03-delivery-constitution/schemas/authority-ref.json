{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixture://schemas/authority-ref.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_version",
    "ref",
    "sha256",
    "schema_ref",
    "schema_sha256"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "minLength": 1
    },
    "ref": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
